upstream diet_tracker_staging_backend {
    server 127.0.0.1:18080;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name staging.tigercloud.asia;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name staging.tigercloud.asia;

    ssl_certificate /etc/letsencrypt/live/staging.tigercloud.asia/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/staging.tigercloud.asia/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    add_header Strict-Transport-Security "max-age=86400" always;

    client_max_body_size 2m;

    location = /actuator/health {
        proxy_pass http://diet_tracker_staging_backend;
        include /etc/nginx/proxy_params;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Request-Id $http_x_request_id;
    }

    location ~ ^/(api|uploads/avatars)/ {
        proxy_pass http://diet_tracker_staging_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header X-Request-Id $http_x_request_id;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;
        proxy_read_timeout 30s;
        proxy_send_timeout 30s;
    }

    location / {
        return 404;
    }
}
