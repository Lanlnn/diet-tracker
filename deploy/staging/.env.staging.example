# Copy to deploy/staging/.env, replace every placeholder, chmod 600, and never commit it.
BACKEND_IMAGE_TAG=replace-with-git-sha
GIT_SHA=replace-with-full-git-sha
BUILD_TIME=replace-with-utc-iso8601

DB_URL="jdbc:mysql://mysql:3306/diet_tracker_staging?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia%2FShanghai&useSSL=false&allowPublicKeyRetrieval=true"
DB_USERNAME=diet_tracker_staging
DB_PASSWORD=replace-with-random-database-password
MYSQL_ROOT_PASSWORD=replace-with-independent-random-root-password

WECHAT_APPID=wx8cfee49a3f7392b2
WECHAT_SECRET=replace-with-rotated-wechat-secret
JWT_SECRET=replace-with-at-least-32-random-ascii-characters
DELETION_AUDIT_PEPPER=replace-with-independent-32-random-ascii-characters

APP_BASE_URL=https://staging.tigercloud.asia
UPLOAD_DIR=/srv/diet-tracker-staging/uploads/avatars
CORS_ALLOWED_ORIGINS=https://staging.tigercloud.asia
SPRING_PROFILES_ACTIVE=prod
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120
BACKEND_BIND_PORT=18080
