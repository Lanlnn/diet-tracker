MAVEN_PROJECTBASEDIR=${MAVEN_BASEDIR:-$(cd "$(dirname "$0")" && pwd)}
MAVEN_WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"

if [ -z "${JAVA_HOME:-}" ]; then
  if [ -x /usr/libexec/java_home ]; then
    JAVA_HOME=$(/usr/libexec/java_home 2>/dev/null)
  else
    JAVA_BIN=$(command -v java 2>/dev/null || true)
    [ -n "$JAVA_BIN" ] && JAVA_HOME=$(cd "$(dirname "$JAVA_BIN")/.." && pwd)
  fi
fi

if [ -z "${JAVA_HOME:-}" ] || [ ! -x "$JAVA_HOME/bin/java" ]; then
  echo "Java 18 is required. Set JAVA_HOME to a valid JDK installation." >&2
  exit 1
fi

JAVA_VERSION_OUTPUT=$("$JAVA_HOME/bin/java" -version 2>&1 | head -n 1)
case "$JAVA_VERSION_OUTPUT" in
  *'version "18.'*|*'version "18"'*) ;;
  *)
    echo "Java 18 is required, but JAVA_HOME reports: $JAVA_VERSION_OUTPUT" >&2
    exit 1
    ;;
esac

if [ ! -f "$MAVEN_WRAPPER_JAR" ]; then
  echo "- Downloading maven-wrapper.jar"
  curl -sS -o "$MAVEN_WRAPPER_JAR" "https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar"
  if [ $? -ne 0 ]; then
    echo "Failed to download maven-wrapper.jar"
    exit 1
  fi
fi

exec "$JAVA_HOME/bin/java" $MAVEN_OPTS -classpath "$MAVEN_WRAPPER_JAR" "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" org.apache.maven.wrapper.MavenWrapperMain "$@"
