<view class="record-page">
  <view class="record-header">
    <view class="back-button" bindtap="goBack"><image src="/assets/icons/chevron-left.svg" mode="aspectFit" /></view>
    <text class="record-title">记录饮食</text>
    <view class="header-spacer"></view>
  </view>

  <view class="search-box">
    <icon type="search" size="18" color="#8A8D84" />
    <input class="search-input" value="{{keyword}}" placeholder="搜索食物或菜品" placeholder-class="search-placeholder" bindinput="onSearchInput" />
    <icon wx:if="{{keyword}}" type="clear" size="18" color="#8A8D84" bindtap="clearSearch" />
  </view>

  <view class="quick-actions">
    <view class="quick-card" bindtap="openPhoto">
      <view class="quick-icon"><image src="/assets/icons/camera.svg" mode="aspectFit" /></view>
      <view><text class="quick-title">拍照留存</text><text class="quick-note">仅保存饮食照片</text></view>
    </view>
    <view class="quick-card" bindtap="openCustomFood">
      <view class="quick-icon"><image src="/assets/icons/plus.svg" mode="aspectFit" /></view>
      <view><text class="quick-title">自定义食物</text><text class="quick-note">录入营养数据</text></view>
    </view>
  </view>

  <view class="scope-tabs">
    <view wx:for="{{scopes}}" wx:key="value" class="scope-tab {{activeScope === item.value ? 'active' : ''}}" data-scope="{{item.value}}" bindtap="selectScope">{{item.label}}</view>
  </view>

  <view class="food-panel">
    <state-view wx:if="{{status === 'loading'}}" state="loading" title="正在准备食品列表" message="稍等一下" />
    <state-view wx:elif="{{status === 'error'}}" state="error" title="食品加载失败" message="{{errorMessage}}" bind:retry="loadFoods" />
    <view wx:elif="{{status === 'empty'}}" class="empty-foods">
      <text class="empty-title">{{keyword ? '没有找到“' + keyword + '”' : '这里还没有食品'}}</text>
      <text class="empty-note">{{keyword ? '可以创建一条自定义食物' : '记录过的食品会出现在这里'}}</text>
      <button wx:if="{{keyword}}" class="empty-action" bindtap="openCustomFood">创建自定义食物</button>
    </view>
    <block wx:else>
      <view wx:for="{{foods}}" wx:key="id" class="food-row" data-id="{{item.id}}" data-name="{{item.name}}" bindtap="selectFood">
        <view class="food-icon">
          <image wx:if="{{item.iconPath}}" src="{{item.iconPath}}" mode="aspectFit" />
          <text wx:else>{{item.initial}}</text>
        </view>
        <view class="food-copy">
          <view class="food-name-line"><text class="food-name">{{item.name}}</text><text wx:if="{{item.custom}}" class="custom-tag">自定义</text></view>
          <text class="food-meta">{{item.calorieLabel}} 千卡 / {{item.basisLabel}}</text>
        </view>
        <view class="add-button"><image src="/assets/icons/plus.svg" mode="aspectFit" /></view>
      </view>
      <button wx:if="{{hasMore}}" class="load-more" loading="{{loadingMore}}" bindtap="loadMore">{{loadingMore ? '加载中' : '查看更多'}}</button>
    </block>
  </view>

  <view class="combination-section">
    <view class="combination-heading"><text>最近组合</text><text class="manage-label">管理</text></view>
    <view wx:if="{{recentCombination}}" class="combination-card" data-id="{{recentCombination.foodId}}" data-name="{{recentCombination.foodName}}" bindtap="selectFood">
      <text class="combination-name">{{recentCombination.names}}</text>
      <view class="combination-value"><text>{{recentCombination.calories}} 千卡</text><image src="/assets/icons/plus.svg" mode="aspectFit" /></view>
    </view>
    <view wx:else class="combination-empty">完成饮食记录后，可快速复用最近组合</view>
  </view>

  <view wx:if="{{customOpen}}" class="sheet-mask" catchtap="closeCustomFood">
    <view class="custom-sheet" catchtap="stopPropagation">
      <view class="sheet-handle"></view>
      <view class="sheet-heading"><text>创建自定义食物</text><text class="sheet-close" bindtap="closeCustomFood">关闭</text></view>
      <text class="sheet-note">营养数据统一按每 100g 填写</text>
      <view class="field"><text class="field-label">食物名称</text><input class="field-input" placeholder="例如：低脂鸡肉卷" value="{{customFood.name}}" data-field="name" bindinput="onCustomInput" maxlength="100" /></view>
      <view class="field"><text class="field-label">热量（千卡）</text><input class="field-input" type="digit" placeholder="0" value="{{customFood.calories}}" data-field="calories" bindinput="onCustomInput" /></view>
      <view class="nutrition-fields">
        <view class="field"><text class="field-label">蛋白质（g）</text><input class="field-input" type="digit" placeholder="0" value="{{customFood.protein}}" data-field="protein" bindinput="onCustomInput" /></view>
        <view class="field"><text class="field-label">脂肪（g）</text><input class="field-input" type="digit" placeholder="0" value="{{customFood.fat}}" data-field="fat" bindinput="onCustomInput" /></view>
        <view class="field"><text class="field-label">碳水（g）</text><input class="field-input" type="digit" placeholder="0" value="{{customFood.carbs}}" data-field="carbs" bindinput="onCustomInput" /></view>
      </view>
      <button class="save-custom" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submitCustomFood">{{submitting ? '创建中' : '创建食物'}}</button>
    </view>
  </view>
</view>
