.date-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.nav-btn {
  font-size: 48rpx;
  color: #4CAF50;
  padding: 0 20rpx;
  font-weight: bold;
}

.date-picker {
  text-align: center;
}

.date-picker text:first-child {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.weekday {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.summary-card {
  padding: 30rpx 20rpx;
}

.summary-row {
  display: flex;
  justify-content: space-around;
}

.summary-item {
  text-align: center;
  display: flex;
  flex-direction: column;
}

.summary-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.summary-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.meal-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.meal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.meal-calories {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
}

.food-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.food-row:last-child {
  border-bottom: none;
}

.food-info {
  display: flex;
  align-items: center;
}

.food-name {
  font-size: 28rpx;
  color: #333;
}

.food-qty {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
}

.food-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.food-cal {
  font-size: 26rpx;
  color: #FF6F00;
}

.delete-btn {
  font-size: 24rpx;
  color: #F44336;
  padding: 4rpx 12rpx;
  border: 1rpx solid #F44336;
  border-radius: 8rpx;
}
