<wxs src="../../shared/format.wxs" module="fmt" />
<view class="container">
  <state-view wx:if="{{pageState === 'loading'}}" state="loading" title="正在准备今日数据" message="稍等一下" />
  <state-view wx:elif="{{pageState === 'error'}}" state="error" title="加载失败" message="{{errorMessage}}" bind:retry="loadData" />
  <block wx:else>
  <view class="header-card">
     <view class="profile-row">
       <view class="avatar-wrap">
         <image wx:if="{{avatarUrl}}" class="avatar" src="{{avatarUrl}}" mode="aspectFill" />
         <view wx:else class="avatar-placeholder">{{nickname ? nickname.slice(0,1) : '微'}}</view>
       </view>
       <view class="profile-info">
         <text class="nickname">{{nickname || '微信用户'}}</text>
         <text class="date-text">{{today}}</text>
         <text class="greeting">{{greeting}}</text>
       </view>
     </view>
  </view>

   <!-- 首次使用：获取微信头像和昵称 -->
   <view wx:if="{{needsWechatInfo && !nickname}}" class="wechat-info-card card">
     <view class="wechat-info-row">
       <button class="avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
         <image wx:if="{{avatarUrl}}" class="wechat-avatar" src="{{avatarUrl}}" mode="aspectFill" />
         <view wx:else class="wechat-avatar-placeholder">+</view>
       </button>
       <view class="wechat-info-fields">
         <text class="wechat-info-label">微信头像</text>
           <input class="nickname-input" type="nickname" placeholder="点此获取微信昵称" bindinput="onNicknameInput" />
         <text class="wechat-info-hint">点击头像和昵称自动获取微信信息</text>
           <view class="manual-section">
             <view class="manual-divider">或手动填写（开发者工具测试用）</view>
             <input class="manual-input" type="text" placeholder="输入昵称" bindinput="onManualNicknameInput" maxlength="20" />
             <input class="manual-input" type="text" placeholder="头像URL（可选）" bindinput="onManualAvatarInput" />
           </view>
       </view>
     </view>
     <view class="wechat-save-btn" bindtap="onSaveWechatInfo">使用微信信息</view>
   </view>

 <view class="summary-card card">
    <view class="summary-row">
      <view class="summary-item">
        <text class="summary-num">{{stats.totalCalories}}</text>
        <text class="summary-label">卡路里</text>
      </view>
      <view class="summary-item">
        <text class="summary-num">{{stats.totalProtein}}g</text>
        <text class="summary-label">蛋白质</text>
      </view>
      <view class="summary-item">
        <text class="summary-num">{{stats.totalFat}}g</text>
        <text class="summary-label">脂肪</text>
      </view>
      <view class="summary-item">
        <text class="summary-num">{{stats.totalCarbs}}g</text>
        <text class="summary-label">碳水</text>
      </view>
    </view>
  </view>

  <view class="section-title">今日饮食</view>

  <view wx:if="{{records.length === 0}}" class="empty-state">
    <text>今天还没有记录，去记录一下吧 📝</text>
  </view>

  <view wx:for="{{mealTypes}}" wx:key="type" class="meal-section" wx:if="{{item.records.length > 0}}" data-meal="{{item.type}}" bindtap="openMeal">
    <view class="meal-header">
      <text class="tag {{item.tagClass}}">{{item.label}}</text>
      <text class="meal-calories">{{item.totalCalories}} kcal</text>
    </view>
    <view wx:for="{{item.records}}" wx:for-item="r" wx:key="id" class="food-row">
      <view class="food-info">
        <text class="food-name">{{r.displayName}}</text>
        <text class="food-qty">{{r.quantity}}{{r.unit}}</text>
      </view>
      <text class="food-cal">{{r.displayCalories}}kcal</text>
    </view>
  </view>
  </block>
</view>
