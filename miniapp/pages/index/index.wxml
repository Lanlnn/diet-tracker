<view class="today-page">
  <view class="today-header">
    <view>
      <text class="date-label">{{dateLabel}}</text>
      <text class="page-title">今天</text>
    </view>
    <view class="calendar-button" bindtap="openCalendar" aria-label="打开饮食日历">
      <image class="calendar-icon" src="/assets/icons/calendar.svg" mode="aspectFit" />
    </view>
  </view>

  <state-view wx:if="{{pageState === 'loading'}}" state="loading" title="正在准备今日数据" message="稍等一下" />
  <state-view wx:elif="{{pageState === 'error'}}" state="error" title="今日数据加载失败" message="{{errorMessage}}" bind:retry="loadData" />

  <block wx:else>
    <view wx:if="{{errorMessage}}" class="refresh-notice" bindtap="retryModule">{{errorMessage}}· 点击重试</view>

    <view class="calorie-card">
      <view class="calorie-main">
        <view class="calorie-ring ring-step-{{ringStep}}">
          <view class="ring-center">
            <text class="ring-caption">还可以吃</text>
            <text class="ring-value">{{remainingLabel}}</text>
            <text class="ring-unit">千卡</text>
          </view>
        </view>
        <view class="calorie-copy">
          <text class="intake-caption">今日摄入</text>
          <text class="intake-value">{{intakeLabel}}</text>
          <text class="goal-copy">目标 {{goalLabel}} 千卡</text>
          <text class="status-copy {{dashboard.exceededCalories > 0 ? 'over' : ''}}">{{calorieStatus}}</text>
          <text class="exercise-copy">运动消耗 {{exerciseLabel}} 千卡</text>
        </view>
      </view>

      <view class="nutrition-divider"></view>
      <view wx:if="{{nutritionState === 'error'}}" class="module-error"><text>营养数据暂时不可用</text><text bindtap="retryModule">重试</text></view>
      <view wx:else class="nutrition-grid">
        <view wx:for="{{nutritionItems}}" wx:key="tone" class="nutrition-item {{item.tone}}">
          <text class="nutrition-value">{{item.amountLabel}}</text>
          <text class="nutrition-label">{{item.label}} · {{item.progressLabel}}</text>
          <view class="progress-track"><view class="progress-fill progress-step-{{item.progressStep}}"></view></view>
        </view>
      </view>
    </view>

    <view class="record-actions">
      <view class="record-button" bindtap="openRecord">{{hasRecords ? '记录一餐' : '记录第一餐'}}</view>
      <view class="camera-button" bindtap="openCamera" aria-label="拍照留存"><image src="/assets/icons/camera.svg" mode="aspectFit" /></view>
    </view>

    <view class="section-heading">
      <text>今日运动</text>
      <text class="section-link" bindtap="openExercise">查看全部</text>
    </view>
    <view wx:if="{{exerciseState === 'error'}}" class="module-card module-error"><text>运动摘要加载失败</text><text bindtap="retryModule">重试</text></view>
    <view wx:elif="{{exerciseState === 'empty'}}" class="exercise-card" bindtap="openExercise">
      <view class="exercise-summary">
        <view class="exercise-icon"><image src="/assets/tabbar/exercise.png" mode="aspectFit" /></view>
        <view class="exercise-text"><text class="exercise-title">今天还没有运动记录</text><text class="exercise-note">可从 10 分钟轻量活动开始</text></view>
        <text class="chevron">›</text>
      </view>
      <view wx:if="{{dashboard.advice}}" class="advice-row"><view class="advice-mark">✦</view><view><text class="advice-title">{{dashboard.advice.title}}</text><text class="advice-note">{{dashboard.advice.message}}</text></view></view>
    </view>
    <view wx:else class="exercise-card" bindtap="openExercise">
      <view class="exercise-summary">
        <view class="exercise-icon"><image src="/assets/tabbar/exercise.png" mode="aspectFit" /></view>
        <view class="exercise-text"><text class="exercise-title">完成 {{dashboard.exercise.completedCount}} 项运动</text><text class="exercise-note">共 {{dashboard.exercise.durationMinutes}} 分钟</text></view>
        <view class="burn-value"><text>{{exerciseLabel}}</text><text>千卡</text></view>
      </view>
      <view wx:if="{{dashboard.advice}}" class="advice-row"><view class="advice-mark">✦</view><view><text class="advice-title">{{dashboard.advice.title}}</text><text class="advice-note">{{dashboard.advice.message}}</text></view><text class="chevron advice-chevron">›</text></view>
    </view>

    <view class="section-heading meal-heading">
      <text>今日饮食</text>
      <text class="meal-count">{{recordedMealCount}} 餐</text>
    </view>
    <view wx:if="{{mealsState === 'error'}}" class="module-card module-error"><text>餐次摘要加载失败</text><text bindtap="retryModule">重试</text></view>
    <view wx:else class="meal-card">
      <view wx:for="{{meals}}" wx:key="type" class="meal-row" data-meal="{{item.type}}" data-count="{{item.itemCount}}" bindtap="openMeal">
        <view class="meal-copy"><text class="meal-name">{{item.label}}</text><text class="meal-preview">{{item.empty ? '尚未记录，点击添加' : item.previewLabel}}</text></view>
        <view class="meal-value"><text>{{item.empty ? '添加' : item.caloriesLabel + ' 千卡'}}</text><text class="chevron">›</text></view>
      </view>
    </view>
  </block>
</view>
