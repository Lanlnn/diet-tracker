<wxs src="../../utils/format.wxs" module="fmt" />
<view class="container">
  <view class="header-card">
    <text class="date-text">{{today}}</text>
    <text class="greeting">{{greeting}}</text>
  </view>

  <view class="summary-card card">
    <view class="summary-row">
      <view class="summary-item">
        <text class="summary-num">{{stats.totalCalories}}</text>
        <text class="summary-label">卡路里</text>
      </view>
      <view class="summary-item">
        <text class="summary-num">{{stats.totalProtein}}g</text>
        <text class="summary-label">蛋白质</text>
      </view>
      <view class="summary-item">
        <text class="summary-num">{{stats.totalFat}}g</text>
        <text class="summary-label">脂肪</text>
      </view>
      <view class="summary-item">
        <text class="summary-num">{{stats.totalCarbs}}g</text>
        <text class="summary-label">碳水</text>
      </view>
    </view>
  </view>

  <view class="section-title">今日饮食</view>

  <view wx:if="{{records.length === 0}}" class="empty-state">
    <text>今天还没有记录，去记录一下吧 📝</text>
  </view>

  <view wx:for="{{mealTypes}}" wx:key="type" class="meal-section" wx:if="{{item.records.length > 0}}">
    <view class="meal-header">
      <text class="tag {{item.tagClass}}">{{item.label}}</text>
      <text class="meal-calories">{{item.totalCalories}} kcal</text>
    </view>
    <view wx:for="{{item.records}}" wx:for-item="r" wx:key="id" class="food-row">
      <view class="food-info">
        <text class="food-name">{{r.foodItem.name}}</text>
        <text class="food-qty">{{r.quantity}}{{r.unit}}</text>
      </view>
      <text class="food-cal">{{fmt.mulFixed(r.foodItem.calories, r.quantity, 0)}}kcal</text>
    </view>
  </view>
</view>
