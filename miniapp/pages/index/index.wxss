.header-card {
  background: linear-gradient(135deg, #4CAF50, #2E7D32);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 24rpx;
  color: #fff;
}

.date-text {
  font-size: 32rpx;
  opacity: 0.9;
}

.greeting {
  font-size: 44rpx;
  font-weight: bold;
  margin-top: 10rpx;
  display: block;
}

.summary-card {
  padding: 30rpx 20rpx;
}

.summary-row {
  display: flex;
  justify-content: space-around;
}

.summary-item {
  text-align: center;
  display: flex;
  flex-direction: column;
}

.summary-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.summary-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin: 20rpx 0 16rpx 0;
  padding-left: 10rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.meal-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.meal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.meal-calories {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
}

.food-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.food-row:last-child {
  border-bottom: none;
}

.food-info {
  display: flex;
  align-items: center;
}

.food-name {
  font-size: 28rpx;
  color: #333;
}

.food-qty {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
}

.food-cal {
  font-size: 26rpx;
  color: #FF6F00;
}
