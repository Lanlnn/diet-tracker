.header-card {
  background: linear-gradient(135deg, #294E3B, #1F3C2D);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 24rpx;
  color: #fff;
}

 .profile-row {
   display: flex;
   align-items: center;
 }
 
 .avatar-wrap {
   width: 100rpx;
   height: 100rpx;
   border-radius: 50%;
   overflow: hidden;
   flex-shrink: 0;
   border: 3rpx solid rgba(255,255,255,0.5);
 }
 
 .avatar {
   width: 100%;
   height: 100%;
 }
 
 .avatar-placeholder {
   width: 100%;
   height: 100%;
   display: flex;
   align-items: center;
   justify-content: center;
   background: rgba(255,255,255,0.25);
   font-size: 40rpx;
   font-weight: bold;
   color: #fff;
 }
 
 .profile-info {
   margin-left: 24rpx;
   flex: 1;
   min-width: 0;
 }
 
 .nickname {
   font-size: 38rpx;
   font-weight: bold;
   display: block;
   margin-bottom: 6rpx;
 }
 
.date-text {
  font-size: 32rpx;
  opacity: 0.9;
   display: block;
}

.greeting {
  font-size: 44rpx;
  font-weight: bold;
  margin-top: 10rpx;
  display: block;
}

 /* 微信信息获取卡片 */
 .wechat-info-card {
   margin-bottom: 24rpx;
   padding: 30rpx;
 }
 
 .wechat-info-row {
   display: flex;
   align-items: flex-start;
 }
 
 .avatar-btn {
   width: 120rpx;
   height: 120rpx;
   border-radius: 50%;
   padding: 0;
   margin: 0;
   background: #f0f0f0;
   border: none;
   flex-shrink: 0;
   display: flex;
   align-items: center;
   justify-content: center;
   overflow: hidden;
 }
 
 .avatar-btn::after {
   border: none;
 }
 
 .wechat-avatar {
   width: 100%;
   height: 100%;
 }
 
 .wechat-avatar-placeholder {
   width: 100%;
   height: 100%;
   display: flex;
   align-items: center;
   justify-content: center;
   font-size: 60rpx;
   color: #ccc;
 }
 
 .wechat-info-fields {
   margin-left: 24rpx;
   flex: 1;
 }
 
 .wechat-info-label {
   font-size: 24rpx;
   color: #999;
   display: block;
   margin-bottom: 8rpx;
 }
 
 .nickname-input {
   width: 100%;
   height: 72rpx;
   border: 1rpx solid #eee;
   border-radius: 12rpx;
   padding: 0 16rpx;
   font-size: 28rpx;
   box-sizing: border-box;
 }
 
 .wechat-info-hint {
   font-size: 22rpx;
   color: #bbb;
   display: block;
   margin-top: 8rpx;
 }
 
 .wechat-save-btn {
   margin-top: 24rpx;
   background: #294E3B;
   color: #fff;
   text-align: center;
   padding: 20rpx;
   border-radius: 40rpx;
   font-size: 28rpx;
 }
 
 .wechat-save-btn:active {
   background: #1F3C2D;
 }
 
 /* 手动输入备用区 */
 .manual-section {
   margin-top: 16rpx;
   padding-top: 16rpx;
 }
 
 .manual-divider {
   font-size: 22rpx;
   color: #ccc;
   text-align: center;
   display: block;
   margin-bottom: 12rpx;
 }
 
 .manual-input {
   width: 100%;
   height: 64rpx;
   border: 1rpx solid #eee;
   border-radius: 10rpx;
   padding: 0 14rpx;
   font-size: 26rpx;
   box-sizing: border-box;
   margin-bottom: 10rpx;
 }

 .summary-card { 
  padding: 30rpx 20rpx;
}

.summary-row {
  display: flex;
  justify-content: space-around;
}

.summary-item {
  text-align: center;
  display: flex;
  flex-direction: column;
}

.summary-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.summary-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin: 20rpx 0 16rpx 0;
  padding-left: 10rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.meal-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.meal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.meal-calories {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
}

.food-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.food-row:last-child {
  border-bottom: none;
}

.food-info {
  display: flex;
  align-items: center;
}

.food-name {
  font-size: 28rpx;
  color: #333;
}

.food-qty {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
}

.food-cal {
  font-size: 26rpx;
  color: #FF6F00;
}
