.today-page { box-sizing: border-box; min-height: 100vh; padding: calc(env(safe-area-inset-top) + 96rpx) 40rpx calc(60rpx + env(safe-area-inset-bottom)); background: var(--color-bg); }
.today-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 44rpx; }
.date-label, .page-title { display: block; }
.date-label { margin-bottom: 8rpx; color: var(--color-text-tertiary); font-size: 25rpx; letter-spacing: .5rpx; }
.page-title { color: #151A15; font-size: 52rpx; font-weight: 760; line-height: 1; }
.calendar-button { display: flex; align-items: center; justify-content: center; width: 80rpx; height: 80rpx; margin-top: 72rpx; background: var(--color-surface); border: 1rpx solid rgba(41, 78, 59, .08); border-radius: 40rpx; }
.calendar-icon { width: 38rpx; height: 38rpx; }
.refresh-notice { margin: -18rpx 0 20rpx; padding: 18rpx 24rpx; color: #885A2E; font-size: 23rpx; text-align: center; background: #F4E4CC; border-radius: 20rpx; }
.calorie-card { padding: 46rpx 40rpx 34rpx; background: var(--color-surface); border-radius: 46rpx; box-shadow: var(--shadow-card); }
.calorie-main { display: flex; align-items: center; }
.calorie-ring { display: flex; flex: 0 0 auto; align-items: center; justify-content: center; width: 278rpx; height: 278rpx; background: conic-gradient(#6E8D62 var(--ring-degrees, 0deg), #E8E7E1 0deg); border-radius: 50%; transform: rotate(-90deg); }
.ring-center { display: flex; flex-direction: column; align-items: center; justify-content: center; width: 226rpx; height: 226rpx; background: var(--color-surface); border-radius: 50%; transform: rotate(90deg); }
.ring-caption { color: var(--color-text-tertiary); font-size: 24rpx; }
.ring-value { margin: 2rpx 0 0; color: #151A15; font-size: 58rpx; font-weight: 760; line-height: 1.1; letter-spacing: -2rpx; }
.ring-unit { color: var(--color-text-tertiary); font-size: 22rpx; }
.calorie-copy { display: flex; flex: 1; flex-direction: column; min-width: 0; margin-left: 42rpx; }
.intake-caption { color: var(--color-text-tertiary); font-size: 25rpx; }
.intake-value { margin: 2rpx 0 8rpx; color: #151A15; font-size: 51rpx; font-weight: 760; line-height: 1.08; }
.goal-copy, .status-copy, .exercise-copy { display: block; font-size: 24rpx; line-height: 1.45; }
.goal-copy { color: var(--color-text-tertiary); }
.status-copy { color: var(--color-text-secondary); }
.status-copy.over { color: var(--color-error); font-weight: 600; }
.exercise-copy { margin-top: 24rpx; color: var(--color-primary); }
.nutrition-divider { height: 1rpx; margin: 38rpx 0 26rpx; background: var(--color-border); }
.nutrition-grid { display: grid; grid-template-columns: repeat(3, 1fr); }
.nutrition-item { min-width: 0; padding: 0 16rpx; border-right: 1rpx solid var(--color-border); }
.nutrition-item:first-child { padding-left: 4rpx; }.nutrition-item:last-child { padding-right: 4rpx; border-right: 0; }
.nutrition-value, .nutrition-label { display: block; }
.nutrition-value { color: #202620; font-size: 29rpx; font-weight: 700; }
.nutrition-label { margin-top: 5rpx; overflow: hidden; color: var(--color-text-tertiary); font-size: 20rpx; text-overflow: ellipsis; white-space: nowrap; }
.progress-track { height: 7rpx; margin-top: 17rpx; overflow: hidden; background: #E8E7E1; border-radius: 4rpx; }
.progress-fill { height: 100%; background: #789371; border-radius: 4rpx; }.nutrition-item.protein .progress-fill { background: #D68B58; }.nutrition-item.fat .progress-fill { background: #C8A34B; }
.record-actions { display: grid; grid-template-columns: 1fr 102rpx; gap: 20rpx; margin-top: 30rpx; }
.record-button, .camera-button { display: flex; align-items: center; justify-content: center; min-height: 96rpx; border-radius: 30rpx; }
.record-button { color: var(--color-surface); font-size: 29rpx; font-weight: 700; background: #4B6C45; box-shadow: 0 20rpx 42rpx rgba(50, 69, 45, .16); }
.camera-button { background: var(--color-surface); border: 1rpx solid var(--color-border); }.camera-button image { width: 39rpx; height: 39rpx; opacity: .76; }
.section-heading { display: flex; align-items: center; justify-content: space-between; margin: 52rpx 4rpx 22rpx; color: #202620; font-size: 34rpx; font-weight: 720; }
.section-link, .meal-count { color: var(--color-primary); font-size: 22rpx; font-weight: 500; }
.exercise-card, .meal-card, .module-card { overflow: hidden; background: var(--color-surface); border-radius: 42rpx; box-shadow: var(--shadow-card); }
.exercise-summary { display: flex; align-items: center; min-height: 130rpx; padding: 0 32rpx; }
.exercise-icon { display: flex; flex: 0 0 auto; align-items: center; justify-content: center; width: 78rpx; height: 78rpx; margin-right: 22rpx; background: #E5EEDF; border-radius: 24rpx; }.exercise-icon image { width: 39rpx; height: 39rpx; opacity: .72; }
.exercise-text { flex: 1; min-width: 0; }.exercise-title, .exercise-note { display: block; }.exercise-title { color: var(--color-text); font-size: 27rpx; font-weight: 680; }.exercise-note { margin-top: 7rpx; color: var(--color-text-tertiary); font-size: 21rpx; }
.chevron { color: var(--color-text-tertiary); font-size: 42rpx; font-weight: 300; }
.burn-value { display: flex; flex-direction: column; align-items: flex-end; color: var(--color-text-tertiary); font-size: 20rpx; }.burn-value text:first-child { color: var(--color-text); font-size: 32rpx; font-weight: 700; }
.advice-row { display: flex; align-items: center; min-height: 118rpx; margin: 0 32rpx; border-top: 1rpx solid var(--color-border); }.advice-mark { margin-right: 22rpx; color: #1F2820; font-size: 28rpx; }.advice-title, .advice-note { display: block; }.advice-title { color: var(--color-text); font-size: 25rpx; font-weight: 650; }.advice-note { margin-top: 5rpx; color: var(--color-text-tertiary); font-size: 20rpx; }
.advice-row > view:nth-child(2) { flex: 1; min-width: 0; }.advice-chevron { margin-left: 12rpx; }
.meal-heading { margin-top: 50rpx; }
.meal-row { display: flex; align-items: center; min-height: 112rpx; margin: 0 30rpx; border-bottom: 1rpx solid var(--color-border); }.meal-row:last-child { border-bottom: 0; }
.meal-copy { flex: 1; min-width: 0; }.meal-name, .meal-preview { display: block; }.meal-name { color: var(--color-text); font-size: 27rpx; font-weight: 650; }.meal-preview { margin-top: 6rpx; overflow: hidden; color: var(--color-text-tertiary); font-size: 21rpx; text-overflow: ellipsis; white-space: nowrap; }
.meal-value { display: flex; align-items: center; gap: 15rpx; margin-left: 20rpx; color: var(--color-primary); font-size: 23rpx; font-weight: 600; }
.module-error { display: flex; align-items: center; justify-content: space-between; min-height: 80rpx; padding: 0 24rpx; color: var(--color-text-tertiary); font-size: 23rpx; }.module-error text:last-child { color: var(--color-primary); font-weight: 650; }
@media (max-width: 350px) { .today-page { padding-right: 28rpx; padding-left: 28rpx; }.calorie-card { padding-right: 28rpx; padding-left: 28rpx; }.calorie-ring { width: 246rpx; height: 246rpx; }.ring-center { width: 200rpx; height: 200rpx; }.calorie-copy { margin-left: 28rpx; }.ring-value { font-size: 50rpx; }.intake-value { font-size: 45rpx; } }
