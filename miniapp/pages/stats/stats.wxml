<view class="trend-page">
  <view class="page-header">
    <view>
      <text class="eyebrow">热量与运动</text>
      <text class="page-title">趋势</text>
    </view>
    <view class="period-badge" aria-label="当前统计日期 {{periodLabel}}">{{periodLabel || '统计周期'}}</view>
  </view>

  <ui-segmented options="{{rangeOptions}}" value="{{selectedRange}}" bind:change="onRangeChange" />

  <state-view wx:if="{{pageState === 'loading'}}" state="loading" title="正在整理趋势" message="正在汇总饮食与运动记录" />
  <state-view wx:elif="{{pageState === 'error'}}" state="error" title="趋势加载失败" message="{{errorMessage}}" bind:retry="retry" />

  <block wx:else>
    <view wx:if="{{refreshing}}" class="refresh-note">正在刷新最新趋势…</view>
    <view wx:if="{{errorMessage}}" class="inline-error">{{errorMessage}}</view>

    <view class="trend-card">
      <view class="metric-head">
        <view>
          <text class="metric-caption">日均净摄入</text>
          <view class="metric-value-row"><text class="metric-value">{{averageNetLabel}}</text><text class="metric-unit">千卡</text></view>
        </view>
        <text class="comparison comparison--{{comparisonTone}}">{{comparisonLabel}}</text>
      </view>

      <scroll-view class="chart-scroll" scroll-x="true" enable-flex="true" show-scrollbar="false">
        <view class="chart {{chartRangeClass}}" role="img" aria-label="{{accessibilitySummary}}">
          <view wx:for="{{chartData}}" wx:key="date" class="bar-column" aria-label="{{item.ariaLabel}}">
            <view class="bar-track">
              <view class="bar bar--{{item.tone}} bar-height-{{item.heightStep}}"></view>
            </view>
            <text class="bar-day">{{item.dayLabel}}</text>
          </view>
        </view>
      </scroll-view>
      <text class="sr-only">{{accessibilitySummary}}</text>

      <view class="metric-grid">
        <view class="metric-grid__item">
          <text>平均摄入</text>
          <view><text class="metric-grid__value">{{averageIntakeLabel}}</text><text> 千卡</text></view>
        </view>
        <view class="metric-grid__item metric-grid__item--border">
          <text>平均运动</text>
          <view><text class="metric-grid__value">{{averageExerciseLabel}}</text><text> 千卡</text></view>
        </view>
        <view class="metric-grid__item metric-grid__item--wide">
          <text>营养达成率</text>
          <view><text class="metric-grid__value">{{achievementRate}}</text><text>%</text></view>
        </view>
      </view>
    </view>

    <text class="summary-title">周期小结</text>
    <view class="summary-list">
      <view wx:for="{{summaries}}" wx:key="type" class="summary-card">
        <view class="summary-icon summary-icon--{{item.tone}}">{{item.icon}}</view>
        <view class="summary-copy">
          <text class="summary-card__title">{{item.title}}</text>
          <text class="summary-card__message">{{item.message}}</text>
        </view>
      </view>
    </view>
  </block>
</view>
