.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.week-chart {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 300rpx;
  padding: 0 10rpx;
}

.bar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-container {
  width: 40rpx;
  height: 200rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
}

.bar {
  position: absolute;
  bottom: 0;
  width: 100%;
  background: linear-gradient(180deg, #294E3B, #78907F);
  border-radius: 20rpx;
  transition: height 0.3s;
}

.bar-info {
  text-align: center;
  margin-top: 10rpx;
}

.bar-cal {
  font-size: 22rpx;
  color: #666;
  display: block;
}

.bar-day {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.nutrient-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.nutrient-row:last-child {
  border-bottom: none;
}

.nutrient-label {
  font-size: 28rpx;
  color: #666;
}

.nutrient-value {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.tip-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}
