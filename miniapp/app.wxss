@import "styles/tokens.wxss";

page {
  min-height: 100%;
  background: #F7F3EA;
  color: #222820;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
}

.container {
  box-sizing: border-box;
  width: 100%;
  min-height: 100vh;
  padding: 24rpx 28rpx calc(40rpx + env(safe-area-inset-bottom));
  overflow-x: hidden;
}

.card {
  box-sizing: border-box;
  width: 100%;
  margin-bottom: 24rpx;
  padding: 32rpx;
  background: #FFFDF8;
  border: 1rpx solid rgba(41, 78, 59, 0.06);
  border-radius: 44rpx;
  box-shadow: 0 10rpx 30rpx rgba(52, 61, 49, 0.06);
}

.section-title {
  margin: 32rpx 0 20rpx;
  color: #222820;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.35;
}

.btn-primary {
  box-sizing: border-box;
  min-height: 88rpx;
  padding: 22rpx 36rpx;
  color: #FFFDF8;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  background: #294E3B;
  border-radius: 44rpx;
}

.btn-primary:active { background: #1F3C2D; transform: scale(0.99); }
.btn-primary.disabled { opacity: 0.42; }

.muted { color: #8A8D84; }
