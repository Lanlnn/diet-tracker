.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.btn-primary {
  background-color: #4CAF50;
  color: #fff;
  border-radius: 40rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
  border: none;
}

.btn-primary:active {
  background-color: #388E3C;
}

.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 10rpx;
}

.tag-breakfast {
  background-color: #FFF3E0;
  color: #F57C00;
}

.tag-lunch {
  background-color: #E8F5E9;
  color: #388E3C;
}

.tag-dinner {
  background-color: #E3F2FD;
  color: #1976D2;
}

.tag-snack {
  background-color: #FCE4EC;
  color: #C2185B;
}
