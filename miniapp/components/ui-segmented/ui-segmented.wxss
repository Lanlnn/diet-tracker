.segmented { box-sizing: border-box; display: flex; width: 100%; min-height: 88rpx; padding: 8rpx; background: #EDE9E0; border-radius: 28rpx; }
.segmented__item { display: flex; flex: 1; align-items: center; justify-content: center; min-width: 0; min-height: 72rpx; padding: 0 12rpx; overflow: hidden; color: #5F665D; font-size: 26rpx; text-overflow: ellipsis; white-space: nowrap; border-radius: 22rpx; }
.segmented__item--active { color: #294E3B; font-weight: 600; background: #FFFDF8; box-shadow: 0 4rpx 12rpx rgba(52,61,49,.08); }
