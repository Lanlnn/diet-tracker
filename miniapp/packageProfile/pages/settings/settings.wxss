.settings-page { padding-top: 44rpx; }
.settings-intro { padding: 24rpx 12rpx 36rpx; }
.settings-title,.settings-copy { display: block; }
.settings-title { color: #222820; font-size: 40rpx; font-weight: 650; }
.settings-copy { margin-top: 16rpx; color: #747A71; font-size: 26rpx; line-height: 1.65; }
.settings-card { padding: 0 32rpx; background: #FFFDF8; border-radius: 40rpx; box-shadow: 0 12rpx 34rpx rgba(52,61,49,.06); }
.settings-row { display: flex; align-items: center; justify-content: space-between; min-height: 112rpx; color: #222820; font-size: 29rpx; border-bottom: 1rpx solid #E9E4DA; }
.settings-row:last-child { border-bottom: 0; }
.arrow { color: #8A8D84; font-size: 36rpx; }
.privacy-note { margin: 30rpx 12rpx; color: #8A8D84; font-size: 23rpx; line-height: 1.65; }
.delete-button { margin-top: 44rpx; color: #A8443C; font-size: 28rpx; background: #FFFDF8; border: 1rpx solid rgba(168,68,60,.18); border-radius: 44rpx; }
.delete-button::after { border: 0; }
