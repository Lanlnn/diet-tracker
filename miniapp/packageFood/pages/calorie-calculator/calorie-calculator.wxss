.calculator-page { box-sizing: border-box; min-height: 100vh; padding: calc(env(safe-area-inset-top) + 72rpx) 40rpx calc(44rpx + env(safe-area-inset-bottom)); background: var(--color-bg); }
.calculator-header { display: flex; align-items: center; justify-content: space-between; height: 88rpx; margin-bottom: 28rpx; }
.back-button, .header-spacer { width: 80rpx; height: 80rpx; }
.back-button { display: flex; align-items: center; justify-content: center; background: var(--color-surface); border-radius: 40rpx; }
.back-icon { width: 38rpx; height: 38rpx; }
.page-title { color: var(--color-text); font-size: 40rpx; font-weight: 700; }
.page-state { display: block; margin-top: 100rpx; }
.food-summary { display: flex; align-items: center; min-height: 126rpx; }
.food-icon { display: flex; flex: 0 0 auto; align-items: center; justify-content: center; width: 104rpx; height: 104rpx; margin-right: 28rpx; color: var(--color-primary); font-size: 34rpx; font-weight: 650; background: #E5EEDF; border-radius: 32rpx; }
.food-image { width: 68rpx; height: 68rpx; }
.food-copy { flex: 1; min-width: 0; }
.food-name, .food-meta { display: block; }
.food-name { overflow: hidden; color: var(--color-text); font-size: 38rpx; font-weight: 700; text-overflow: ellipsis; white-space: nowrap; }
.food-meta { margin-top: 10rpx; color: var(--color-text-tertiary); font-size: 23rpx; }
.calculation-card { box-sizing: border-box; margin-top: 24rpx; padding: 36rpx 40rpx 26rpx; background: var(--color-surface); border-radius: 44rpx; box-shadow: var(--shadow-card); }
.input-label { display: block; color: var(--color-text-tertiary); font-size: 23rpx; text-align: center; }
.formula-line { margin-top: 12rpx; color: var(--color-text-tertiary); font-size: 27rpx; text-align: center; }
.formula-amount { color: var(--color-text); font-size: 36rpx; font-weight: 700; }
.amount-control { display: grid; grid-template-columns: 96rpx minmax(0, 1fr) 96rpx; align-items: center; gap: 24rpx; margin-top: 24rpx; }
.step-button { display: flex; align-items: center; justify-content: center; width: 96rpx; height: 96rpx; margin: 0; padding: 0; color: var(--color-text); font-size: 48rpx; line-height: 96rpx; background: #F0EFEB; border-radius: 30rpx; }
.step-button-pressed { opacity: .72; }
.amount-field { box-sizing: border-box; display: flex; flex: 1; align-items: center; justify-content: center; min-width: 0; height: 128rpx; border: 2rpx solid #66825B; border-radius: 40rpx; }
.amount-field.invalid { border-color: var(--color-error); }
.amount-input { width: 118rpx; height: 100rpx; color: var(--color-text); font-size: 66rpx; font-weight: 700; text-align: right; }
.amount-unit { margin-left: 10rpx; color: var(--color-text-tertiary); font-size: 27rpx; }
.field-error { display: block; margin-top: 12rpx; color: var(--color-error); font-size: 22rpx; text-align: center; }
.quick-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14rpx; margin-top: 24rpx; }
.quick-value { display: flex; align-items: center; justify-content: center; min-height: 68rpx; padding: 0 8rpx; color: var(--color-text-secondary); font-size: 22rpx; text-align: center; border: 1rpx solid var(--color-border); border-radius: 22rpx; }
.quick-value.active { color: var(--color-primary); font-weight: 650; background: #E5EEDF; border-color: #E5EEDF; }
.quick-value.disabled { opacity: .38; }
.serving-detail { font-size: 18rpx; }
.calorie-result { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 176rpx; margin-top: 28rpx; color: var(--color-surface); background: #4E7046; border-radius: 34rpx; }
.result-caption { font-size: 23rpx; opacity: .78; }
.result-number { font-size: 66rpx; font-weight: 750; }
.result-unit { font-size: 25rpx; font-weight: 650; }
.nutrition-row { display: flex; align-items: center; justify-content: space-between; min-height: 68rpx; color: var(--color-text-secondary); font-size: 25rpx; border-bottom: 1rpx solid var(--color-border); }
.nutrition-row:last-child { border-bottom: 0; }
.nutrition-value { color: var(--color-text); font-weight: 650; }
.dot { display: inline-block; width: 13rpx; height: 13rpx; margin-right: 16rpx; border-radius: 50%; }
.dot.protein { background: #779962; }.dot.fat { background: #E69B5B; }.dot.carbs { background: #D8B04C; }
.option-card { box-sizing: border-box; display: block; margin-top: 24rpx; background: var(--color-surface); border-radius: 28rpx; }
.option-row, .note-card { display: flex; align-items: center; justify-content: space-between; min-height: 92rpx; padding: 0 30rpx; color: var(--color-text); font-size: 26rpx; }
.option-value { display: flex; align-items: center; font-weight: 650; }
.chevron { margin-left: 18rpx; color: var(--color-text-tertiary); font-size: 36rpx; font-weight: 400; }
.note-input { flex: 1; height: 92rpx; margin-left: 30rpx; color: var(--color-text-secondary); font-size: 24rpx; text-align: right; }
.draft-note { display: block; margin: 24rpx 16rpx 0; color: var(--color-text-tertiary); font-size: 21rpx; line-height: 1.5; text-align: center; }
.submit-button { box-sizing: border-box; display: flex; align-items: center; justify-content: center; width: 100%; height: 106rpx; margin: 22rpx 0 0; color: var(--color-surface); font-size: 29rpx; font-weight: 700; white-space: nowrap; background: #4E7046; border-radius: 34rpx; }
.submit-button.disabled { color: var(--color-surface); background: #9FAE99; opacity: .72; }
.submit-button-pressed { background: var(--color-primary-pressed); }
@media (max-width: 340px) { .calculator-page { padding-right: 24rpx; padding-left: 24rpx; } .calculation-card { padding-right: 24rpx; padding-left: 24rpx; } .amount-control { gap: 14rpx; } .step-button { width: 82rpx; } }
