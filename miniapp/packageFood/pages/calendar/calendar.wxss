.calendar-page { box-sizing: border-box; min-height: 100vh; padding: calc(env(safe-area-inset-top) + 96rpx) 40rpx calc(60rpx + env(safe-area-inset-bottom)); background: var(--color-bg); }
.page-header { display: flex; align-items: center; justify-content: space-between; min-height: 92rpx; margin-bottom: 30rpx; }
.icon-button, .header-spacer { width: 76rpx; height: 76rpx; }
.icon-button { display: flex; align-items: center; justify-content: center; background: rgba(255, 253, 248, .92); border: 1rpx solid rgba(41, 78, 59, .06); border-radius: 38rpx; }
.icon-button image { width: 32rpx; height: 32rpx; }
.page-title { color: #171C17; font-size: 36rpx; font-weight: 720; letter-spacing: 1rpx; }
.refresh-notice { margin: 0 0 18rpx; padding: 16rpx 22rpx; color: #885A2E; font-size: 22rpx; text-align: center; background: #F4E4CC; border-radius: 20rpx; }
.month-nav { display: flex; align-items: center; justify-content: space-between; min-height: 82rpx; margin-bottom: 30rpx; }
.month-label { color: #202520; font-size: 34rpx; font-weight: 720; }
.month-button { display: flex; align-items: center; justify-content: center; width: 72rpx; height: 72rpx; background: var(--color-surface); border-radius: 24rpx; }
.month-button image { width: 26rpx; height: 26rpx; }.month-button.next image { transform: rotate(180deg); }.month-button.disabled { opacity: .3; }
.calendar-card { padding: 28rpx 18rpx 30rpx; background: var(--color-surface); border-radius: 44rpx; box-shadow: var(--shadow-card); }
.weekday-row, .day-grid { display: grid; grid-template-columns: repeat(7, 1fr); }
.weekday-row { margin-bottom: 10rpx; }.weekday-row text { color: #7D827A; font-size: 20rpx; text-align: center; }
.day-cell { position: relative; display: flex; align-items: center; justify-content: center; height: 84rpx; color: #202520; font-size: 23rpx; border-radius: 24rpx; }
.day-cell.outside { color: #BFC1BB; }.day-cell.future { color: #9EA29A; }.day-cell.today { color: #3F6546; font-weight: 720; background: #E5EDDF; }.day-cell.selected { color: #FFFFFF; font-weight: 720; background: #496B48; }.day-cell.selected.outside { color: #FFFFFF; }
.record-dot { position: absolute; bottom: 8rpx; width: 7rpx; height: 7rpx; background: #6E8D62; border-radius: 50%; }.day-cell.selected .record-dot { background: #DCE9D5; }
.summary-card { margin-top: 30rpx; padding: 52rpx 34rpx 44rpx; background: var(--color-surface); border-radius: 42rpx; box-shadow: var(--shadow-card); }
.summary-top { display: flex; align-items: center; justify-content: space-between; }
.summary-copy { display: flex; min-width: 0; flex-direction: column; }.selected-date { color: var(--color-text-tertiary); font-size: 21rpx; }.intake-value { margin-top: 4rpx; color: #171C17; font-size: 42rpx; font-weight: 760; letter-spacing: -1rpx; }
.progress-ring { display: flex; align-items: center; justify-content: center; width: 94rpx; height: 94rpx; background: #E5E4DD; border-radius: 50%; transform: rotate(-90deg); }
.progress-center { display: flex; align-items: center; justify-content: center; width: 74rpx; height: 74rpx; background: var(--color-surface); border-radius: 50%; transform: rotate(90deg); }.progress-center text { color: #435845; font-size: 20rpx; font-weight: 700; }
.ring-step-1 { background: conic-gradient(#6E8D62 18deg, #E5E4DD 0deg); }.ring-step-2 { background: conic-gradient(#6E8D62 36deg, #E5E4DD 0deg); }.ring-step-3 { background: conic-gradient(#6E8D62 54deg, #E5E4DD 0deg); }.ring-step-4 { background: conic-gradient(#6E8D62 72deg, #E5E4DD 0deg); }.ring-step-5 { background: conic-gradient(#6E8D62 90deg, #E5E4DD 0deg); }
.ring-step-6 { background: conic-gradient(#6E8D62 108deg, #E5E4DD 0deg); }.ring-step-7 { background: conic-gradient(#6E8D62 126deg, #E5E4DD 0deg); }.ring-step-8 { background: conic-gradient(#6E8D62 144deg, #E5E4DD 0deg); }.ring-step-9 { background: conic-gradient(#6E8D62 162deg, #E5E4DD 0deg); }.ring-step-10 { background: conic-gradient(#6E8D62 180deg, #E5E4DD 0deg); }
.ring-step-11 { background: conic-gradient(#6E8D62 198deg, #E5E4DD 0deg); }.ring-step-12 { background: conic-gradient(#6E8D62 216deg, #E5E4DD 0deg); }.ring-step-13 { background: conic-gradient(#6E8D62 234deg, #E5E4DD 0deg); }.ring-step-14 { background: conic-gradient(#6E8D62 252deg, #E5E4DD 0deg); }.ring-step-15 { background: conic-gradient(#6E8D62 270deg, #E5E4DD 0deg); }
.ring-step-16 { background: conic-gradient(#6E8D62 288deg, #E5E4DD 0deg); }.ring-step-17 { background: conic-gradient(#6E8D62 306deg, #E5E4DD 0deg); }.ring-step-18 { background: conic-gradient(#6E8D62 324deg, #E5E4DD 0deg); }.ring-step-19 { background: conic-gradient(#6E8D62 342deg, #E5E4DD 0deg); }.ring-step-20 { background: #6E8D62; }
.summary-divider { height: 1rpx; margin: 26rpx 0 22rpx; background: var(--color-border); }
.metric-row { display: grid; grid-template-columns: repeat(3, 1fr); }.metric { display: flex; min-width: 0; flex-direction: column; padding: 0 18rpx; border-right: 1rpx solid var(--color-border); }.metric:first-child { padding-left: 8rpx; }.metric:last-child { padding-right: 8rpx; border-right: 0; }.metric text:first-child { color: #252A25; font-size: 28rpx; font-weight: 720; }.metric text:last-child { margin-top: 4rpx; color: var(--color-text-tertiary); font-size: 19rpx; white-space: nowrap; }
.detail-heading { display: flex; align-items: center; justify-content: space-between; margin: 46rpx 6rpx 20rpx; color: #202520; font-size: 32rpx; font-weight: 720; }.detail-link, .retry-link { color: var(--color-primary); font-size: 21rpx; font-weight: 600; }
.detail-card { overflow: hidden; background: var(--color-surface); border-radius: 36rpx; box-shadow: var(--shadow-card); }.detail-state { display: flex; align-items: center; justify-content: space-between; min-height: 112rpx; padding: 0 28rpx; color: var(--color-text-tertiary); font-size: 22rpx; }.detail-state.empty { justify-content: center; }
.meal-row { display: flex; align-items: center; min-height: 112rpx; margin: 0 28rpx; border-bottom: 1rpx solid var(--color-border); }.meal-row:last-child { border-bottom: 0; }
.meal-badge { display: flex; flex: 0 0 auto; align-items: center; justify-content: center; width: 64rpx; height: 64rpx; margin-right: 20rpx; color: #526653; font-size: 21rpx; font-weight: 700; background: #E7EEE2; border-radius: 20rpx; }.meal-badge.noon { color: #7B6332; background: #F2E8D3; }.meal-badge.evening { color: #455B66; background: #E5EBEC; }.meal-badge.snack { color: #775C55; background: #EFE4E0; }
.meal-copy { flex: 1; min-width: 0; }.meal-title, .meal-preview { display: block; }.meal-title { color: #242924; font-size: 25rpx; font-weight: 680; }.meal-preview { max-width: 330rpx; margin-top: 5rpx; overflow: hidden; color: var(--color-text-tertiary); font-size: 20rpx; text-overflow: ellipsis; white-space: nowrap; }.meal-calories { margin-left: 16rpx; color: #222722; font-size: 23rpx; white-space: nowrap; }
@media (max-width: 350px) { .calendar-page { padding-right: 28rpx; padding-left: 28rpx; }.calendar-card { padding-right: 12rpx; padding-left: 12rpx; }.day-cell { height: 68rpx; }.summary-card { padding-right: 26rpx; padding-left: 26rpx; }.metric { padding: 0 10rpx; } }
