.meal-page { box-sizing: border-box; min-height: 100vh; padding: calc(72rpx + env(safe-area-inset-top)) 40rpx 0; background: #F7F3EA; }
.meal-header { display: flex; align-items: center; justify-content: space-between; height: 96rpx; margin-bottom: 28rpx; }
.round-button { display: flex; align-items: center; justify-content: center; width: 76rpx; height: 76rpx; background: #FFFDF8; border: 1rpx solid rgba(41,78,59,.08); border-radius: 50%; }
.round-button image { width: 32rpx; height: 32rpx; }
.page-title { font-size: 36rpx; font-weight: 700; color: #222820; }
.more-button { gap: 7rpx; }.more-button text { width: 7rpx; height: 7rpx; background: #222820; border-radius: 50%; }
.calorie-card { display: flex; align-items: center; min-height: 138rpx; padding: 24rpx 32rpx; box-sizing: border-box; background: #FFFDF8; border-radius: 44rpx; box-shadow: var(--shadow-card); }
.meal-mark { position: relative; display: flex; align-items: center; justify-content: center; width: 76rpx; height: 76rpx; margin-right: 26rpx; overflow: hidden; background: #F1E4CC; border-radius: 28rpx; }
.meal-mark::before { content: ''; width: 34rpx; height: 34rpx; border: 3rpx solid #222820; border-radius: 50%; }
.meal-mark-half { position: absolute; width: 17rpx; height: 36rpx; left: 38rpx; background: #222820; border-radius: 0 18rpx 18rpx 0; }
.calorie-copy { flex: 1; }.record-time { display: block; margin-bottom: 2rpx; color: #8A8D84; font-size: 22rpx; }.calorie-number,.calorie-unit { color: #222820; font-size: 40rpx; font-weight: 700; }.calorie-unit { font-size: 34rpx; }
.edit-toggle,.add-link { color: #46623D; font-size: 24rpx; }.edit-toggle { padding: 24rpx 0 24rpx 24rpx; }
.macro-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20rpx; margin: 28rpx 0 42rpx; }.macro-item { padding: 24rpx 10rpx; text-align: center; background: rgba(255,253,248,.72); border-radius: 30rpx; }.macro-value,.macro-label { display: block; }.macro-value { color: #222820; font-size: 28rpx; font-weight: 700; }.macro-label { margin-top: 8rpx; color: #7B8077; font-size: 21rpx; }
.list-heading { display: flex; align-items: center; justify-content: space-between; margin: 0 4rpx 22rpx; font-size: 34rpx; font-weight: 700; }.add-link { font-weight: 400; }
.food-list { padding: 0 30rpx; background: #FFFDF8; border-radius: 44rpx; box-shadow: var(--shadow-card); }.food-row { position: relative; display: flex; align-items: center; min-height: 130rpx; border-bottom: 1rpx solid #E9E4DA; }.food-row:last-child { border-bottom: 0; }.food-row.editable { opacity: .94; }
.food-icon { display: flex; align-items: center; justify-content: center; flex: 0 0 72rpx; height: 72rpx; margin-right: 22rpx; overflow: hidden; color: #294E3B; font-size: 26rpx; font-weight: 700; background: #F0F0EB; border-radius: 24rpx; }.food-icon image { width: 58rpx; height: 58rpx; }
.food-copy { flex: 1; min-width: 0; }.food-name,.food-meta,.food-calories,.food-macro { display: block; }.food-name { color: #222820; font-size: 27rpx; font-weight: 600; }.food-meta { margin-top: 7rpx; color: #8A8D84; font-size: 20rpx; white-space: nowrap; }
.food-nutrition { width: 150rpx; text-align: right; }.food-calories { color: #222820; font-size: 27rpx; }.food-macro { margin-top: 7rpx; color: #747A71; font-size: 19rpx; }.row-chevron { margin-left: 10rpx; color: #8A8D84; font-size: 34rpx; }
.advice-card { display: flex; align-items: center; margin-top: 28rpx; padding: 28rpx 30rpx; background: #FFFDF8; border-radius: 40rpx; box-shadow: var(--shadow-card); }.advice-icon { display: flex; align-items: center; justify-content: center; flex: 0 0 70rpx; height: 70rpx; margin-right: 24rpx; color: #222820; font-size: 24rpx; background: #F1E4CC; border-radius: 24rpx; }.advice-title,.advice-detail { display: block; }.advice-title { color: #222820; font-size: 25rpx; font-weight: 600; }.advice-detail { margin-top: 7rpx; color: #747A71; font-size: 21rpx; line-height: 1.45; }
.bottom-spacer { height: 160rpx; }.bottom-bar { position: fixed; z-index: 5; right: 0; bottom: 0; left: 0; padding: 22rpx 40rpx calc(22rpx + env(safe-area-inset-bottom)); background: linear-gradient(180deg,rgba(247,243,234,0),#F7F3EA 24%); }.continue-button,.empty-action { height: 94rpx; color: #FFFDF8; font-size: 29rpx; font-weight: 600; line-height: 94rpx; background: #4C7044; border-radius: 34rpx; }.continue-button::after,.empty-action::after,.save-button::after,.delete-button::after { border: 0; }
.empty-panel { padding-top: 40rpx; }.empty-action { width: 300rpx; margin: 0 auto; }
.sheet-mask { position: fixed; z-index: 20; inset: 0; display: flex; align-items: flex-end; background: rgba(22,28,22,.34); }.edit-sheet { box-sizing: border-box; width: 100%; padding: 18rpx 40rpx calc(36rpx + env(safe-area-inset-bottom)); background: #FFFDF8; border-radius: 48rpx 48rpx 0 0; }.sheet-handle { width: 76rpx; height: 8rpx; margin: 0 auto 24rpx; background: #D7D2C8; border-radius: 8rpx; }.sheet-title { display: block; margin-bottom: 24rpx; font-size: 34rpx; font-weight: 700; }.field { margin-top: 18rpx; }.field-label { display: block; margin-bottom: 10rpx; color: #5F665D; font-size: 23rpx; }.input-wrap,.note-input,.option-field { box-sizing: border-box; width: 100%; min-height: 86rpx; padding: 20rpx 24rpx; background: #F7F3EA; border-radius: 24rpx; }.input-wrap { display: flex; align-items: center; }.input-wrap input { flex: 1; min-width: 0; font-size: 28rpx; }.input-unit { color: #8A8D84; font-size: 24rpx; }.option-field { display: flex; align-items: center; justify-content: space-between; }.option-field .field-label { margin: 0; }.note-input { font-size: 27rpx; }.field-error { display: block; margin-top: 8rpx; color: #B65346; font-size: 22rpx; }.save-button,.delete-button { height: 88rpx; margin-top: 26rpx; color: #FFFDF8; line-height: 88rpx; background: #294E3B; border-radius: 30rpx; }.delete-button { margin-top: 14rpx; color: #B65346; background: transparent; }
